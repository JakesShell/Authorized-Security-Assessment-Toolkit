def utc_now():
    return datetime.now(timezone.utc).isoformat()


def detect_local_ip():
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)

    try:
        sock.connect(("8.8.8.8", 80))
        local_ip = sock.getsockname()[0]
    except OSError:
        local_ip = socket.gethostbyname(socket.gethostname())
    finally:
        sock.close()

    if local_ip.startswith("127."):
        candidates = socket.getaddrinfo(socket.gethostname(), None, socket.AF_INET)
        for candidate in candidates:
            possible_ip = candidate[4][0]
            if not possible_ip.startswith("127."):
                local_ip = possible_ip
                break

    ip = ipaddress.ip_address(local_ip)
    if not ip.is_private:
        raise ValueError("Current network detection only supports private LAN/Wi-Fi addresses.")

    return local_ip


def get_current_network():
    local_ip = detect_local_ip()
    network = ipaddress.ip_network(f"{local_ip}/24", strict=False)
    return local_ip, network


def ping_host(host):
    system = platform.system().lower()

    if "windows" in system:
        command = ["ping", "-n", "1", "-w", "500", host]
    else:
        command = ["ping", "-c", "1", "-W", "1", host]

    try:
        result = subprocess.run(
            command,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=1.8,
        )
        return result.returncode == 0
    except Exception:
        return False


def get_hostname(ip_address):
    try:
        name = socket.gethostbyaddr(ip_address)[0]
        if name and name != ip_address:
            return name
    except Exception:
        pass

    return "Unknown"


def load_arp_table():
    arp_map = {}

    try:
        result = subprocess.run(
            ["arp", "-a"],
            capture_output=True,
            text=True,
            timeout=3,
        )
    except Exception:
        return arp_map

    output = result.stdout or ""
    pattern = re.compile(
        r"(?P<ip>\d{1,3}(?:\.\d{1,3}){3})\s+"
        r"(?P<mac>[0-9a-fA-F]{2}(?:[-:][0-9a-fA-F]{2}){5})"
    )

    for match in pattern.finditer(output):
        ip = match.group("ip")
        mac = match.group("mac").replace("-", ":").upper()
        arp_map[ip] = mac

    return arp_map


def guess_vendor_from_hostname_or_mac(hostname, mac_address):
    text = f"{hostname} {mac_address}".lower()

    for keyword, names in COMMON_VENDOR_PREFIXES.items():
        if keyword in text:
            return names[0]

    if mac_address and mac_address != "Unknown":
        return "MAC visible, vendor unknown"

    return "Unknown"


def guess_device_type(host, hostname, vendor, open_ports, ping_reply, local_ip):
    hostname_lower = (hostname or "").lower()
    vendor_lower = (vendor or "").lower()
    ports = {item.get("port") for item in open_ports}

    if host == local_ip:
        return "Teacher machine"

    if host.endswith(".1") or "router" in hostname_lower or "gateway" in hostname_lower:
        return "Router or gateway"

    if vendor_lower in {"apple", "samsung", "oppo", "vivo", "xiaomi", "huawei", "honor", "oneplus", "google"}:
        return "Phone or tablet"

    if vendor_lower in {"tp-link", "d-link", "netgear", "ubiquiti", "mikrotik"}:
        return "Network device"

    if vendor_lower in {"epson", "canon", "brother"}:
        return "Printer"

    if 3389 in ports or 445 in ports:
        return "Windows laptop or desktop"

    if 22 in ports and (80 in ports or 443 in ports):
        return "Server, router, or Linux device"

    if 80 in ports or 443 in ports or 8080 in ports:
        return "Web-enabled device"

    if ping_reply and not open_ports:
        return "Phone, laptop, or protected device"

    return "Unknown device"


def scan_current_lan(include_ping=True):
    local_ip, network = get_current_network()
    hosts = [str(host) for host in network.hosts()]
    ports = get_default_port_set("device")

    discovered = []

    def scan_host(host):
        ping_reply = ping_host(host) if include_ping else False
        open_ports = []

        for port in ports:
            try:
                result = check_single_port(host, port)
                if result["state"] == "open":
                    open_ports.append(result)
            except OSError:
                continue

        if ping_reply or open_ports:
            return {
                "host": host,
                "is_teacher_machine": host == local_ip,
                "responded_to_ping": ping_reply,
                "open_port_count": len(open_ports),
                "open_ports": open_ports,
                "highest_risk": highest_risk(open_ports) if open_ports else "low",
                "detection_note": "Detected by ping and service response" if ping_reply and open_ports else (
                    "Detected by ping only" if ping_reply else "Detected by open service response"
                ),
            }

        return None

    with ThreadPoolExecutor(max_workers=64) as pool:
        future_map = {pool.submit(scan_host, host): host for host in hosts}
        for future in as_completed(future_map):
            item = future.result()
            if item:
                discovered.append(item)

    arp_map = load_arp_table()

    for device in discovered:
        host = device["host"]
        hostname = get_hostname(host)
        mac_address = arp_map.get(host, "Unknown")
        vendor = guess_vendor_from_hostname_or_mac(hostname, mac_address)
        device_type = guess_device_type(
            host=host,
            hostname=hostname,
            vendor=vendor,
            open_ports=device.get("open_ports", []),
            ping_reply=device.get("responded_to_ping", False),
            local_ip=local_ip,
        )

        device["hostname"] = hostname
        device["mac_address"] = mac_address
        device["vendor_guess"] = vendor
        device["device_type_guess"] = device_type

    discovered.sort(key=lambda item: tuple(int(part) for part in item["host"].split(".")))

    return {
        "scan_type": "current_wifi_lan_discovery",
        "cidr": str(network),
        "local_ip": local_ip,
        "timestamp": utc_now(),
        "hosts_reviewed": len(hosts),
        "devices_found": len(discovered),
        "devices": discovered,
        "classroom_note": "Best-effort classroom scan. Phones may appear only if they reply to ping, appear in ARP, or expose a visible service.",
        "recommendations": build_discovery_recommendations(discovered),
    }


def get_classroom_join_link():
    local_ip = detect_local_ip()
    return {
        "local_ip": local_ip,
        "student_url": f"http://{local_ip}:5050/student",
        "teacher_url": "http://127.0.0.1:5050",
        "note": "Students must be on the same Wi-Fi/LAN as the teacher laptop.",
    }
