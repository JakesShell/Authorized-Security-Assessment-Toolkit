:root {
    --bg: #080a0d;
    --panel: rgba(20, 24, 30, 0.78);
    --panel-strong: rgba(28, 34, 43, 0.94);
    --line: rgba(255, 255, 255, 0.11);
    --text: #f4f0e8;
    --muted: #a9b0ba;
    --gold: #d6a84f;
    --amber: #ffbc5c;
    --green: #6dd8a8;
    --red: #ff6b6b;
    --blue: #8fb5ff;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
}

* {
    box-sizing: border-box;
}

html {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    scroll-behavior: smooth;
}

body {
    margin: 0;
    min-height: 100vh;
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    background:
        radial-gradient(circle at 12% 8%, rgba(214, 168, 79, 0.18), transparent 30%),
        radial-gradient(circle at 88% 12%, rgba(143, 181, 255, 0.18), transparent 28%),
        linear-gradient(135deg, #080a0d 0%, #111821 48%, #07090c 100%);
    color: var(--text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button,
input,
select {
    font: inherit;
}

button {
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
}

button:hover {
    transform: translateY(-1px);
}

.shell {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(14px, 2.5vw, 34px);
}

.hero {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(260px, 360px);
    gap: clamp(14px, 2vw, 24px);
    align-items: stretch;
    margin-bottom: 22px;
}

.hero-copy,
.score-card,
.panel,
.bottom-cta,
.kpi-grid article {
    border: 1px solid var(--line);
    background: var(--panel);
    box-shadow: var(--shadow);
    backdrop-filter: blur(22px);
    min-width: 0;
}

.hero-copy {
    padding: clamp(24px, 4vw, 44px);
    border-radius: clamp(22px, 3vw, 34px);
    position: relative;
    overflow: hidden;
}

.hero-copy::after {
    content: "";
    position: absolute;
    inset: auto -80px -120px auto;
    width: 360px;
    height: 360px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(214, 168, 79, 0.24), transparent 62%);
    pointer-events: none;
}

.eyebrow {
    margin: 0 0 12px;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.74rem;
    font-weight: 800;
}

h1,
h2,
h3,
p {
    margin-top: 0;
}

h1 {
    margin-bottom: 14px;
    font-size: clamp(3rem, 7vw, 6.4rem);
    line-height: 0.88;
    letter-spacing: -0.08em;
}

h2 {
    margin-bottom: 10px;
    font-size: clamp(1.55rem, 3vw, 2.4rem);
    letter-spacing: -0.04em;
}

h3 {
    margin-bottom: 8px;
}

.subtitle {
    max-width: 720px;
    color: var(--muted);
    font-size: clamp(0.98rem, 1.5vw, 1.08rem);
    line-height: 1.7;
}

.hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
}

.primary-btn,
.secondary-btn,
.action-card button {
    border: 0;
    border-radius: 999px;
    padding: 13px 18px;
    cursor: pointer;
    font-weight: 800;
    text-decoration: none;
}

.primary-btn,
.action-card button {
    color: #181105;
    background: linear-gradient(135deg, #ffdd92, var(--gold));
    box-shadow: 0 14px 34px rgba(214, 168, 79, 0.25);
}

.secondary-btn {
    color: var(--text);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--line);
}

.score-card {
    border-radius: clamp(22px, 3vw, 34px);
    padding: clamp(22px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.score-label {
    color: var(--muted);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.76rem;
}

.score-card strong {
    display: block;
    margin: 10px 0;
    font-size: clamp(3.7rem, 8vw, 5.4rem);
    line-height: 1;
    letter-spacing: -0.08em;
}

.score-rating,
.pill {
    width: fit-content;
    border-radius: 999px;
    padding: 7px 11px;
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 900;
    white-space: nowrap;
}

.score-card p {
    color: var(--muted);
    line-height: 1.55;
    margin-top: 18px;
    margin-bottom: 0;
}

.kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 22px;
}

.kpi-grid article {
    border-radius: 24px;
    padding: clamp(16px, 2vw, 22px);
}

.kpi-grid span {
    display: block;
    color: var(--muted);
    font-size: 0.85rem;
    margin-bottom: 8px;
}

.kpi-grid strong {
    font-size: 2rem;
}

.workspace {
    display: grid;
    grid-template-columns: minmax(280px, 410px) minmax(0, 1fr);
    gap: clamp(14px, 2vw, 22px);
    align-items: start;
    width: 100%;
    max-width: 100%;
}

.panel {
    border-radius: clamp(22px, 3vw, 30px);
    padding: clamp(18px, 2.4vw, 26px);
    min-width: 0;
    max-width: 100%;
}

.command-panel {
    position: sticky;
    top: 18px;
}

.panel-heading p:not(.eyebrow) {
    color: var(--muted);
    line-height: 1.6;
}

.action-grid {
    display: grid;
    gap: 14px;
}

.action-card {
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: clamp(16px, 2vw, 20px);
    background: rgba(255, 255, 255, 0.045);
    min-width: 0;
}

.action-card p {
    color: var(--muted);
    line-height: 1.5;
}

input,
select {
    width: 100%;
    margin-bottom: 10px;
    color: var(--text);
    background: rgba(0, 0, 0, 0.22);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 13px 14px;
    outline: none;
    min-width: 0;
}

input:focus,
select:focus {
    border-color: rgba(214, 168, 79, 0.68);
}

.action-card button {
    width: 100%;
    margin-top: 4px;
}

.results-panel {
    min-height: 620px;
    overflow: visible;
}

.results-area {
    margin-top: 18px;
    min-width: 0;
    width: 100%;
    max-width: 100%;
    overflow: visible;
}

.empty-state,
.error-box,
.result-summary {
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: clamp(18px, 2.4vw, 22px);
    background: rgba(255, 255, 255, 0.05);
    max-width: 100%;
}

.empty-state {
    display: grid;
    place-items: center;
    min-height: 240px;
    color: var(--muted);
    text-align: center;
}

.empty-state span {
    font-size: 4rem;
    margin-bottom: 8px;
}

.error-box {
    border-color: rgba(255, 107, 107, 0.35);
    background: rgba(255, 107, 107, 0.08);
}

.error-box small {
    color: var(--muted);
}

.table-wrap {
    width: 100%;
    overflow-x: auto;
    margin-top: 14px;
    border: 1px solid var(--line);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.025);
}

table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
}

th,
td {
    padding: 13px 12px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
}

th {
    color: var(--gold);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
}

td {
    color: #e8e4dc;
}

td strong {
    color: var(--text);
}

.risk-high,
.risk-critical {
    color: #2a0707;
    background: var(--red);
}

.risk-medium,
.risk-watch,
.risk-moderate {
    color: #2b1601;
    background: var(--amber);
}

.risk-low,
.risk-strong {
    color: #052418;
    background: var(--green);
}

.lan-summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(145px, 180px);
    gap: 18px;
    align-items: center;
}

.lan-summary p {
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 10px;
    overflow-wrap: anywhere;
}

.lan-count-card {
    border: 1px solid rgba(214, 168, 79, 0.35);
    border-radius: 22px;
    padding: 18px;
    background: rgba(214, 168, 79, 0.09);
    text-align: center;
}

.lan-count-card span {
    display: block;
    color: var(--gold);
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
}

.lan-count-card strong {
    display: block;
    margin-top: 8px;
    font-size: 3rem;
    line-height: 1;
}

.inventory-section {
    margin-top: 20px;
}

.inventory-section p {
    color: var(--muted);
    line-height: 1.5;
}

.inventory-card-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
    gap: 14px;
    margin-top: 14px;
    width: 100%;
}

.inventory-card {
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.045);
    min-width: 0;
    max-width: 100%;
}

.inventory-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 14px;
    min-width: 0;
}

.inventory-card-header > div {
    min-width: 0;
}

.inventory-card-header strong {
    display: block;
    font-size: 1.15rem;
    overflow-wrap: anywhere;
}

.label,
.fluid-detail-grid span {
    display: block;
    color: var(--muted);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
}

.teacher-tag {
    display: block;
    margin-top: 4px;
    color: var(--gold);
    font-size: 0.78rem;
    font-weight: 800;
}

.fluid-detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 145px), 1fr));
    gap: 10px;
}

.fluid-detail-grid div {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 10px;
    background: rgba(0, 0, 0, 0.16);
    min-width: 0;
}

.fluid-detail-grid strong {
    display: block;
    color: var(--text);
    font-size: 0.92rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
    word-break: break-word;
}

.recommendations {
    margin-top: 22px;
    display: grid;
    gap: 12px;
}

.recommendations article {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 14px;
    background: rgba(255, 255, 255, 0.045);
    min-width: 0;
}

.recommendations p {
    margin: 5px 0 0;
    color: var(--muted);
    line-height: 1.5;
    overflow-wrap: anywhere;
}

.loader {
    width: 42px;
    height: 42px;
    margin: 20px 0;
    border-radius: 999px;
    border: 4px solid rgba(255, 255, 255, 0.15);
    border-top-color: var(--gold);
    animation: spin 0.8s linear infinite;
}

.hidden {
    display: none;
}

.bottom-cta {
    margin-top: 22px;
    border-radius: 30px;
    padding: clamp(20px, 3vw, 30px);
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: center;
}

.bottom-cta p:not(.eyebrow) {
    color: var(--muted);
    max-width: 720px;
    line-height: 1.6;
    margin-bottom: 0;
}

pre {
    white-space: pre-wrap;
    color: var(--text);
    overflow-wrap: anywhere;
}

.mini-list {
    margin-top: 14px;
    display: grid;
    gap: 8px;
}

.mini-list small {
    color: var(--muted);
}

.mini-row {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 10px;
    background: rgba(255, 255, 255, 0.04);
}

.mini-row strong,
.mini-row span {
    display: block;
}

.mini-row span {
    color: var(--muted);
    font-size: 0.82rem;
    margin-top: 3px;
}

.student-shell {
    min-height: 100vh;
    width: min(760px, calc(100% - 30px));
    margin: 0 auto;
    display: grid;
    place-items: center;
    padding: 30px 0;
}

.student-card {
    width: 100%;
    border: 1px solid var(--line);
    background: var(--panel);
    box-shadow: var(--shadow);
    border-radius: 34px;
    padding: 34px;
    backdrop-filter: blur(22px);
}

.student-card h1 {
    font-size: clamp(3rem, 12vw, 6rem);
}

.student-form {
    display: grid;
    gap: 12px;
    margin-top: 24px;
}

.check-row {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    color: var(--muted);
    line-height: 1.5;
    padding: 12px 0;
}

.check-row input {
    width: auto;
    margin-top: 4px;
}

.student-result {
    margin-top: 22px;
    border: 1px solid var(--line);
    border-radius: 24px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.05);
    text-align: center;
}

.big-eye {
    display: block;
    font-size: 4rem;
    margin-bottom: 10px;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}

@media (max-width: 1180px) {
    .workspace {
        grid-template-columns: 1fr;
    }

    .command-panel {
        position: static;
    }

    .action-grid {
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 290px), 1fr));
    }
}

@media (max-width: 980px) {
    .hero,
    .kpi-grid {
        grid-template-columns: 1fr;
    }

    .bottom-cta {
        align-items: flex-start;
        flex-direction: column;
    }
}

@media (max-width: 720px) {
    .shell {
        padding: 12px;
    }

    h1 {
        font-size: clamp(2.7rem, 15vw, 3.5rem);
    }

    .hero-copy,
    .score-card,
    .panel,
    .bottom-cta {
        border-radius: 22px;
    }

    .lan-summary {
        grid-template-columns: 1fr;
    }

    .lan-count-card {
        text-align: left;
    }

    .recommendations article {
        flex-direction: column;
    }

    table {
        min-width: 560px;
    }
}

@media (max-width: 430px) {
    .hero-actions {
        flex-direction: column;
    }

    .primary-btn,
    .secondary-btn,
    .action-card button {
        width: 100%;
        text-align: center;
    }

    .student-card {
        padding: 22px;
        border-radius: 24px;
    }
}
